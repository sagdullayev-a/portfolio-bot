# Telegram Bot — required environment variables.
# Copy this file to ".env" and fill in real values. Never commit ".env".

# Token from @BotFather (Phase 1).
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your personal Telegram chat ID, where admin notifications are sent.
# NOTE: You discover this in Phase 3 via the /whoami command.
# For Phase 1 verification, put a placeholder (e.g. 0) — it is not used yet.
TELEGRAM_ADMIN_CHAT_ID=0

# Optional runtime flags.
NODE_ENV=development
